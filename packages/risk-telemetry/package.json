{
  "name": "@auto-job/risk-telemetry",
  "version": "0.1.0",
  "private": true,
  "description": "Append-only telemetry log + detection-signal heuristics + auto-cooldown registry. Used by auto-apply, email-bot, and scan scripts to observe operational health.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
