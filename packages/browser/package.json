{
  "name": "@auto-job/browser",
  "version": "0.1.0",
  "private": true,
  "description": "In-process CDP-attached browser automation library replacing the bb-browser PATH dependency. Phase 1 = read path (scan); Phase 2 = write path (auto-apply).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./sites/builtin": {
      "types": "./src/sites/builtin/index.ts",
      "development": "./src/sites/builtin/index.ts",
      "default": "./dist/sites/builtin/index.js"
    },
    "./sites/indeed": {
      "types": "./src/sites/indeed/index.ts",
      "development": "./src/sites/indeed/index.ts",
      "default": "./dist/sites/indeed/index.js"
    },
    "./sites/jobright": {
      "types": "./src/sites/jobright/index.ts",
      "development": "./src/sites/jobright/index.ts",
      "default": "./dist/sites/jobright/index.js"
    },
    "./sites/linkedin": {
      "types": "./src/sites/linkedin/index.ts",
      "development": "./src/sites/linkedin/index.ts",
      "default": "./dist/sites/linkedin/index.js"
    },
    "./sites/greenhouse": {
      "types": "./src/sites/greenhouse/index.ts",
      "development": "./src/sites/greenhouse/index.ts",
      "default": "./dist/sites/greenhouse/index.js"
    },
    "./sites/workday": {
      "types": "./src/sites/workday/index.ts",
      "development": "./src/sites/workday/index.ts",
      "default": "./dist/sites/workday/index.js"
    },
    "./sites/icims": {
      "types": "./src/sites/icims/index.ts",
      "development": "./src/sites/icims/index.ts",
      "default": "./dist/sites/icims/index.js"
    },
    "./sites": {
      "types": "./src/sites/registry.ts",
      "development": "./src/sites/registry.ts",
      "default": "./dist/sites/registry.js"
    },
    "./bb-shim": {
      "types": "./src/bb-shim.ts",
      "development": "./src/bb-shim.ts",
      "default": "./dist/bb-shim.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "playwright": "^1.58.1"
  }
}
