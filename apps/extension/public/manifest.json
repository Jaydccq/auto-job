{
  "manifest_version": 3,
  "name": "auto-job",
  "short_name": "auto-job",
  "version": "0.2.0",
  "description": "Local-first job posting evaluation. Bridges your browser to the auto-job pipeline running on your machine.",
  "action": {
    "default_title": "auto-job — toggle panel"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://www.newgrad-jobs.com/*",
    "https://jobright.ai/*",
    "https://builtin.com/*",
    "https://www.builtin.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Toggle auto-job panel"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
